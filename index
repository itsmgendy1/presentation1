<!DOCTYPE html>
<html lang="en">
<head>
<!-- skill:chassis -->
<style>
/* =====================================================
   PRESENTATION CHASSIS — style-invariant base styles
   Fixed 1920×1080 canvas scaled to fit any viewport.
   Customize colors, fonts, and chrome via :root tokens.
   ===================================================== */

/* ---------- Universal reset ---------- */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

/* ---------- Theme tokens (override in your deck's CSS) ---------- */
:root {
    color-scheme: light;

    --background:      #ffffff;
    --foreground:      #111111;
    --card:            #f5f5f5;
    --card-foreground: var(--foreground);
    --accent:          #c94a3d;
    --accent-foreground: #ffffff;

    --muted-foreground: color-mix(in srgb, var(--foreground) 55%, transparent);
    --border:           color-mix(in srgb, var(--foreground) 12%, transparent);

    --font-display: Georgia, serif;
    --font-body: -apple-system, system-ui, sans-serif;
    --font-mono: ui-monospace, monospace;

    /* Reveal animation */
    --reveal-duration: 0.8s;
    --reveal-ease:     cubic-bezier(0.16, 1, 0.3, 1);
    --reveal-distance: 28px;

    /* Chrome (nav dots, keyboard hint) */
    --nav-dot-size: 9px;
    --nav-dot-radius: 50%;
    --nav-dot-color: var(--foreground);
    --nav-dot-active-color: var(--accent);
    --nav-dot-opacity: 0.4;
}

/* ---------- Viewport lock + scroll snap ---------- */
html, body { height: 100%; overflow-x: hidden; }
html {
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
}

html, body {
    scrollbar-width: none;
    -ms-overflow-style: none;
}
html::-webkit-scrollbar,
body::-webkit-scrollbar {
    width: 0;
    height: 0;
    display: none;
}

/* ---------- Type scale ----------
   Fixed px sizes on a 1920×1080 canvas. The canvas is scaled to fit
   any viewport via transform, so these sizes are absolute within the
   design surface — no responsive units needed. */
body {
    background: var(--background);
    color: var(--foreground);
    font-family: var(--font-body);
    font-size: 36px;
    line-height: 1.45;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

h1 { font-size: 120px; line-height: 1.05; letter-spacing: -0.02em; }
h2 { font-size: 64px; line-height: 1.1; letter-spacing: -0.01em; }
h3 { font-size: 44px; line-height: 1.2; }
.eyebrow {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.3;
}

ul, ol { padding-left: 48px; display: flex; flex-direction: column; gap: 24px; }
li::marker { color: var(--accent); }

/* ---------- Slide structure ----------
   .slide is the authored 1920×1080 artboard.
   The chassis wraps it in viewport + scale layers at runtime. */
.slide-viewport {
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: block;
    position: relative;
    background: var(--background);
    isolation: isolate;
    z-index: 1;
}

.slide-scale {
    width: 1920px;
    height: 1080px;
    transform: translate(-50%, -50%) scale(var(--slide-scale, 1));
    transform-origin: center center;
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 1;
}

.slide {
    width: 1920px;
    height: 1080px;
    padding: 80px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 60px;
    position: relative;
    background: transparent;
}


/* ---------- Image defaults ---------- */
img, .image-container {
    max-width: 100%;
    max-height: 540px;
    object-fit: contain;
}

/* ---------- Reveal primitives ----------
   Driven by chassis.js via the Web Animations API, not CSS transitions.
   Put .reveal* or .step on ANY element — author CSS on the same element
   (opacity, transform, transition, filter) never conflicts, because
   WAAPI animations live in the animation cascade origin and win over
   normal author declarations. The .dN stagger classes below still apply
   to theme-authored CSS animations via animation-delay.

   Variants: .reveal (fade + up), .reveal-left, .reveal-right,
   .reveal-scale, .reveal-blur. .step stays hidden until the user
   advances forward. Don't combine .step with .reveal* on the same
   element. */

/* FOUC guard: hide reveals until chassis.js marks the document ready. */
:root:not(.reveals-ready) .reveal,
:root:not(.reveals-ready) .reveal-left,
:root:not(.reveals-ready) .reveal-right,
:root:not(.reveals-ready) .reveal-scale,
:root:not(.reveals-ready) .reveal-blur,
:root:not(.reveals-ready) .step {
    opacity: 0;
}
:root:not(.reveals-ready) .reveal-blur { filter: blur(10px); }

/* ---------- Stagger delays (.d1 … .d8) ---------- */
.slide.visible .d1 { transition-delay: 0.10s; animation-delay: 0.10s; }
.slide.visible .d2 { transition-delay: 0.25s; animation-delay: 0.25s; }
.slide.visible .d3 { transition-delay: 0.40s; animation-delay: 0.40s; }
.slide.visible .d4 { transition-delay: 0.55s; animation-delay: 0.55s; }
.slide.visible .d5 { transition-delay: 0.70s; animation-delay: 0.70s; }
.slide.visible .d6 { transition-delay: 0.85s; animation-delay: 0.85s; }
.slide.visible .d7 { transition-delay: 1.00s; animation-delay: 1.00s; }
.slide.visible .d8 { transition-delay: 1.15s; animation-delay: 1.15s; }

/* ---------- Nav dots ----------
   Default: right-center (vertical stack on right edge).
   Override with <body data-nav="bottom | top-right | hidden">. */
.nav-dots {
    position: fixed;
    right: clamp(0.6rem, 1.5vw, 1.4rem);
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, 1vh, 0.8rem);
    z-index: 50;
}

body[data-nav="bottom"] .nav-dots {
    right: auto;
    top: auto;
    bottom: clamp(1rem, 2.5vh, 2rem);
    left: 50%;
    transform: translateX(-50%);
    flex-direction: row;
}

body[data-nav="top-right"] .nav-dots {
    right: clamp(1rem, 2.5vw, 2rem);
    top: clamp(1rem, 2.5vh, 2rem);
    transform: none;
    flex-direction: row;
}

body[data-nav="hidden"] .nav-dots { display: none; }

body[data-nav="bottom"] .keyboard-hint {
    left: clamp(1rem, 2vw, 1.5rem);
    transform: none;
}

.nav-dots button {
    width: var(--nav-dot-size);
    height: var(--nav-dot-size);
    border-radius: var(--nav-dot-radius);
    border: 1.5px solid var(--nav-dot-color);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
    opacity: var(--nav-dot-opacity);
}
.nav-dots button:hover { opacity: 0.85; transform: scale(1.15); }
.nav-dots button:focus-visible {
    outline: 2px solid var(--nav-dot-active-color);
    outline-offset: 3px;
    opacity: 1;
}
.nav-dots button.active {
    background: var(--nav-dot-active-color);
    border-color: var(--nav-dot-active-color);
    opacity: 1;
    transform: scale(1.2);
}

/* ---------- Keyboard hint ---------- */
.keyboard-hint {
    position: fixed;
    bottom: clamp(0.6rem, 1.2vh, 1rem);
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--muted-foreground);
    z-index: 50;
    opacity: 0.7;
    transition: opacity 0.4s ease;
    pointer-events: none;
}
.keyboard-hint kbd {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.9em;
    padding: 0.05em 0.4em;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--background);
    margin: 0 0.15em;
}

/* ---------- Credit line ---------- */
.chassis-credit {
    position: fixed;
    bottom: clamp(0.6rem, 1.2vh, 1rem);
    left: clamp(1rem, 2vw, 1.5rem);
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--muted-foreground);
    letter-spacing: 0.02em;
    z-index: 50;
    opacity: 0.7;
    transition: opacity 0.4s ease;
    pointer-events: none;
}
.chassis-credit .chassis-credit-emoji {
    font-style: normal;
    margin: 0 0.15em;
}

body[data-nav="bottom"] .chassis-credit {
    left: auto;
    right: clamp(1rem, 2vw, 1.5rem);
}

/* ---------- Custom cursor ---------- */
.chassis-cursor {
    position: fixed;
    top: 0; left: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    pointer-events: none;
    background: var(--accent);
    z-index: 9999;
    opacity: 0;
    transition: opacity 0.4s ease;
    will-change: transform;
}
.chassis-cursor.visible { opacity: 1; }
body.artifact-editor-editing .chassis-cursor { display: none; }

@media (hover: none) {
    .chassis-cursor { display: none; }
}

body.chassis-cursor-active:not(.artifact-editor-editing),
body.chassis-cursor-active:not(.artifact-editor-editing) * { cursor: none; }

/* ---------- Opt-outs ---------- */
body[data-no-chrome] .nav-dots,
body[data-no-chrome] .keyboard-hint,
body[data-no-chrome] .chassis-credit,
body[data-no-chrome] .chassis-cursor,
body[data-no-chrome] .artifact-editor-toggle { display: none; }

:fullscreen .keyboard-hint,
:fullscreen .chassis-credit,
:fullscreen .artifact-editor-toggle { display: none; }

@media (hover: none) {
    .keyboard-hint,
    .chassis-credit { display: none; }
}

@media (max-width: 900px), (max-height: 560px) {
    .nav-dots,
    .keyboard-hint,
    .chassis-credit,
    .chassis-cursor { display: none; }
}

/* ---------- Reduced motion ---------- */
@media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.2s !important;
    }
    html { scroll-behavior: auto; }
}

/* ---------- Print (PDF export) ---------- */
@media print {
    .nav-dots, .keyboard-hint, .chassis-credit, .chassis-cursor { display: none !important; }
    html, body { height: auto; overflow: visible; }
    html { scroll-snap-type: none; }
    .slide-viewport {
        page-break-after: always;
        break-after: page;
        height: 100vh;
    }
    .slide-scale {
        position: static !important;
        transform: none !important;
        width: 100% !important;
        height: auto !important;
    }
    .slide {
        width: 100% !important;
        height: auto !important;
    }
}

</style>
<script>
/* =====================================================
   PRESENTATION CHASSIS — slide controller
   Auto-initializes on DOMContentLoaded.
   Exposes window.slides for programmatic control.
   ===================================================== */
(function () {
    'use strict';

    const REVEAL_SELECTOR = '.reveal, .reveal-left, .reveal-right, .reveal-scale, .reveal-blur';
    const STEP_SELECTOR = '.step';
    const ALL_REVEAL_SELECTOR = REVEAL_SELECTOR + ', ' + STEP_SELECTOR;
    const VIEWPORT_CLASS = 'slide-viewport';
    const SCALE_CLASS = 'slide-scale';

    function _detectLang() {
        const param = new URLSearchParams(location.search).get('lang');
        return (param || navigator.language || 'en').slice(0, 2).toLowerCase();
    }

    class SlidePresentation {
        constructor() {
            this.slides = Array.from(document.querySelectorAll('.slide'));
            if (this.slides.length === 0) return;

            // Ensure every slide has an id so hashes + anchor links work.
            // Author-defined ids are preserved; the rest get slide-N (1-indexed).
            this.slides.forEach((slide, idx) => {
                if (!slide.id) slide.id = `slide-${idx + 1}`;
            });
            this.viewports = this._setupViewports();
            this.scales = this.viewports.map((viewport) => viewport.querySelector(`.${SCALE_CLASS}`));

            // Hide every reveal element BEFORE lifting the CSS FOUC guard.
            // After this, .reveals-ready is on <html>, so CSS no longer hides
            // reveals — inline styles keep them hidden until JS animates them.
            this._setupReveals();

            this.navDotsContainer = this._ensureNavDots();
            this.keyboardHint = this._ensureKeyboardHint();
            this.credit = this._ensureCredit();

            this._setupCanvasScale();
            this._setupIntersectionObserver();
            this._setupKeyboardNav();
            this._setupWheelNav();
            this._setupTouchNav();
            this._setupViewportSync();
            this._buildNavDots();
            this._setupHashNav();
            this._setupCursor();
            this._setupPrintSettling();

            // If URL has a matching hash, start there; otherwise start at slide 0.
            const initial = this._slideIndexFromHash(location.hash);
            this.currentSlide = initial >= 0 ? initial : 0;
            if (this.currentSlide !== 0) {
                this._scrollToSlide(this.currentSlide, 'auto');
            }
            // Reveal initial slide immediately (observer may miss it on load).
            const first = this.slides[this.currentSlide];
            first.classList.add('visible');
            this._playSlideReveals(first);
            this._updateNavDots();
        }

        /* ---------- Viewport scaffolding ----------
           Authors write .slide as the 1920×1080 artboard. The chassis wraps
           that authored section in viewport and scale layers. */
        _setupViewports() {
            return this.slides.map((slide) => {
                const existingScale = slide.parentElement?.classList.contains(SCALE_CLASS)
                    ? slide.parentElement
                    : null;
                const existingViewport = existingScale?.parentElement?.classList.contains(VIEWPORT_CLASS)
                    ? existingScale.parentElement
                    : null;
                if (existingViewport) {
                    this._syncViewportBackground(slide, existingViewport);
                    return existingViewport;
                }

                const viewport = document.createElement('div');
                viewport.className = VIEWPORT_CLASS;
                const scale = document.createElement('div');
                scale.className = SCALE_CLASS;

                slide.parentNode.insertBefore(viewport, slide);
                viewport.appendChild(scale);
                scale.appendChild(slide);
                this._syncViewportBackground(slide, viewport);

                return viewport;
            });
        }

        _syncViewportBackground(slide, viewport) {
            const style = getComputedStyle(slide);
            const hasBackgroundImage = style.backgroundImage && style.backgroundImage !== 'none';
            const hasBackgroundColor = !['rgba(0, 0, 0, 0)', 'transparent'].includes(style.backgroundColor);
            if (hasBackgroundImage || hasBackgroundColor) {
                viewport.style.background = style.background;
            } else {
                viewport.style.background = '';
            }
            slide.style.background = 'transparent';
        }

        /* ---------- DOM scaffolding (auto-inserted if missing) ---------- */
        _ensureNavDots() {
            let el = document.getElementById('navDots');
            if (!el) {
                el = document.createElement('nav');
                el.id = 'navDots';
                el.className = 'nav-dots';
                el.setAttribute('aria-label', 'Slide navigation');
                document.body.appendChild(el);
            }
            return el;
        }

        _ensureKeyboardHint() {
            let el = document.querySelector('.keyboard-hint');
            if (!el) {
                const i18n = {
                    en: { navigate: 'navigate', restart: 'restart', fullscreen: 'fullscreen' },
                    es: { navigate: 'navegar',   restart: 'inicio',   fullscreen: 'fullscreen' },
                    fr: { navigate: 'naviguer',  restart: 'début',    fullscreen: 'fullscreen' },
                    de: { navigate: 'blättern',  restart: 'anfang',   fullscreen: 'vollbild' },
                    pt: { navigate: 'navegar',   restart: 'início',   fullscreen: 'fullscreen' },
                    ja: { navigate: '移動',      restart: '先頭',      fullscreen: '全画面' },
                    ko: { navigate: '이동',      restart: '처음',      fullscreen: '전체화면' },
                    zh: { navigate: '翻页',      restart: '重置',      fullscreen: '全屏' },
                    it: { navigate: 'navigare',  restart: 'inizio',   fullscreen: 'fullscreen' },
                    nl: { navigate: 'bladeren',  restart: 'begin',    fullscreen: 'vollscherm' },
                };
                const t = i18n[_detectLang()] || i18n.en;
                el = document.createElement('div');
                el.className = 'keyboard-hint';
                el.innerHTML = `<kbd>←</kbd> <kbd>→</kbd> ${t.navigate} &middot; <kbd>R</kbd> ${t.restart} &middot; <kbd>F</kbd> ${t.fullscreen}`;
                document.body.appendChild(el);
            }
            return el;
        }

        _ensureCredit() {
            let el = document.querySelector('.chassis-credit');
            if (!el) {
                el = document.createElement('div');
                el.className = 'chassis-credit';
                el.setAttribute('aria-hidden', 'true');
                el.innerHTML = '💜 by ClickUp Brain';
                document.body.appendChild(el);
            }
            return el;
        }

        /* ---------- Reveal engine ----------
           Reveals are driven by the Web Animations API instead of CSS
           transitions. This lets authors put .reveal* / .step on any
           element: animation values live in the animation cascade origin
           and win over normal author declarations, so no wrapper element
           is required to isolate the chassis from author CSS.

           State per slide:
           - "hidden":  inline opacity/transform/filter from the 'from'
                        keyframe of the variant. Set on init and on
                        forward re-entry.
           - "played":  animation is running or has run; the class
                        `reveals-played` on the slide makes playback
                        idempotent so observer re-fires (resize,
                        fullscreen) don't restart the animation.
           - "settled": animation canceled, inline styles cleared. Used
                        for backward entries (we skip the animation and
                        show the final state instantly) and for print. */

        _setupReveals() {
            // Lift the CSS FOUC guard first so getComputedStyle reads each
            // element's natural opacity, not the guard's blanket opacity: 0.
            // No paint occurs mid-task — inline hidden styles are applied
            // before the browser yields, so there is no visible flash.
            document.documentElement.classList.add('reveals-ready');
            this.slides.forEach((slide) => {
                slide.querySelectorAll(ALL_REVEAL_SELECTOR).forEach((el) => {
                    el._targetOpacity = parseFloat(getComputedStyle(el).opacity);
                    this._applyHiddenStyle(el);
                });
            });
        }

        _setupPrintSettling() {
            // Browsers snapshot the document for print/PDF export. WAAPI
            // animations don't necessarily complete in that snapshot, so
            // settle every slide to its final state first. After printing,
            // reset — but only for slides that haven't already been viewed,
            // so the audience experience picks up where it left off.
            window.addEventListener('beforeprint', () => {
                this.slides.forEach((slide) => this._settleSlide(slide));
            });
        }

        _readTokens() {
            const cs = getComputedStyle(document.documentElement);
            const rawDuration = parseFloat(cs.getPropertyValue('--reveal-duration'));
            const duration = Number.isFinite(rawDuration) ? rawDuration * 1000 : 800;
            const ease = cs.getPropertyValue('--reveal-ease').trim() || 'cubic-bezier(0.16, 1, 0.3, 1)';
            const distance = cs.getPropertyValue('--reveal-distance').trim() || '28px';
            const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
            return {
                duration: reducedMotion ? 1 : duration,
                ease,
                distance,
            };
        }

        _getRevealDelay(el) {
            // Use getAttribute('class') rather than el.className: on SVG
            // elements, `.className` is an SVGAnimatedString (not a string)
            // and calling .match on it throws. getAttribute is uniform
            // across HTML and SVG.
            const classes = el.getAttribute('class') || '';
            const m = classes.match(/\bd([1-8])\b/);
            if (!m) return 0;
            // Matches CSS .dN: d1 = 100ms, d2 = 250ms, +150ms per step.
            return 100 + (parseInt(m[1], 10) - 1) * 150;
        }

        _getRevealKeyframes(el, distance) {
            const to = el._targetOpacity ?? 1;
            if (el.classList.contains('reveal-left')) {
                return [
                    { opacity: 0, transform: `translateX(calc(-1 * ${distance}))` },
                    { opacity: to, transform: 'translateX(0)' },
                ];
            }
            if (el.classList.contains('reveal-right')) {
                return [
                    { opacity: 0, transform: `translateX(${distance})` },
                    { opacity: to, transform: 'translateX(0)' },
                ];
            }
            if (el.classList.contains('reveal-scale')) {
                return [
                    { opacity: 0, transform: 'scale(0.88)' },
                    { opacity: to, transform: 'scale(1)' },
                ];
            }
            if (el.classList.contains('reveal-blur')) {
                return [
                    { opacity: 0, filter: 'blur(10px)' },
                    { opacity: to, filter: 'blur(0)' },
                ];
            }
            // Default: .reveal or .step (slide up + fade)
            return [
                { opacity: 0, transform: `translateY(${distance})` },
                { opacity: to, transform: 'translateY(0)' },
            ];
        }

        _applyHiddenStyle(el) {
            const { distance } = this._readTokens();
            const from = this._getRevealKeyframes(el, distance)[0];
            if ('opacity' in from) el.style.opacity = from.opacity;
            if ('transform' in from) el.style.transform = from.transform;
            if ('filter' in from) el.style.filter = from.filter;
        }

        _clearHiddenStyle(el) {
            el.style.opacity = '';
            el.style.transform = '';
            el.style.filter = '';
        }

        _cancelReveal(el) {
            if (el._revealAnim) {
                el._revealAnim.cancel();
                el._revealAnim = null;
            }
        }

        _playReveal(el, delayOverride) {
            this._cancelReveal(el);
            const { duration, ease, distance } = this._readTokens();
            const delay = typeof delayOverride === 'number' ? delayOverride : this._getRevealDelay(el);
            const keyframes = this._getRevealKeyframes(el, distance);
            // fill: 'backwards' applies the 'from' keyframe during the
            // stagger delay so the element stays hidden until its turn,
            // without pinning the 'to' keyframe after the animation ends.
            // This lets co-existing author CSS (e.g. a `.pulse` CSS
            // animation on the same element) take over naturally once the
            // entrance completes — otherwise our fill would mask anything
            // the author wanted to happen post-reveal.
            const anim = el.animate(keyframes, {
                duration,
                delay,
                easing: ease,
                fill: 'backwards',
            });
            el._revealAnim = anim;
            // Safe to clear inline 'from' styles now — the animation's
            // backwards-fill holds the element at the 'from' keyframe for
            // the duration of any stagger delay.
            this._clearHiddenStyle(el);
        }

        _playSlideReveals(slide) {
            if (slide.classList.contains('reveals-played')) return;
            slide.classList.add('reveals-played');
            slide.querySelectorAll(REVEAL_SELECTOR).forEach((el) => this._playReveal(el));
            // .step elements stay hidden until the user advances.
        }

        _resetSlideReveals(slide) {
            // Forward re-entry: cancel in-flight animations, re-hide
            // everything, and reset step state so the slide replays cleanly
            // when the observer next adds .visible.
            slide.classList.remove('reveals-played');
            slide.querySelectorAll(ALL_REVEAL_SELECTOR).forEach((el) => {
                this._cancelReveal(el);
                this._applyHiddenStyle(el);
            });
            slide.querySelectorAll('.step.step-shown').forEach((el) => el.classList.remove('step-shown'));
        }

        _settleSlide(slide) {
            // Print / PDF export: jump to the final state with everything
            // shown, so every step appears in the exported document.
            slide.classList.add('reveals-played');
            slide.querySelectorAll(ALL_REVEAL_SELECTOR).forEach((el) => {
                this._cancelReveal(el);
                this._clearHiddenStyle(el);
            });
            slide.querySelectorAll('.step').forEach((el) => el.classList.add('step-shown'));
        }

        _rewindSlide(slide) {
            // Backward re-entry: show reveals instantly (no replay — the
            // viewer already saw the intro) but hide every step, so the
            // slide is positioned at the start of its stepped content and
            // can be stepped through again.
            slide.classList.add('reveals-played');
            slide.querySelectorAll(REVEAL_SELECTOR).forEach((el) => {
                this._cancelReveal(el);
                this._clearHiddenStyle(el);
            });
            slide.querySelectorAll('.step').forEach((el) => {
                el.classList.remove('step-shown');
                this._cancelReveal(el);
                this._applyHiddenStyle(el);
            });
        }

        /* ---------- Navigation ----------
           goTo scrolls to the target. Both forward-replay and backward-
           rewind need to mutate the target BEFORE scrolling — while it's
           still offscreen — so the viewer never sees the old state flash
           into view. Resetting after the slide is in view causes a visible
           "show then hide" blink; the IntersectionObserver fires too late
           (80% threshold) to catch it. */
        goTo(index) {
            const clamped = Math.max(0, Math.min(this.slides.length - 1, index));
            if (clamped === this.currentSlide) return;

            const target = this.slides[clamped];
            const goingForward = clamped > this.currentSlide;

            if (target.classList.contains('visible')) {
                if (goingForward) {
                    // Forward replay: full reset so the observer can play reveals fresh.
                    target.classList.remove('visible');
                    this._resetSlideReveals(target);
                } else {
                    // Backward rewind: hide any shown steps so the slide
                    // scrolls back in at the start of its stepped content.
                    this._rewindSlide(target);
                }
            }

            this._scrollToSlide(clamped, 'smooth');
        }

        _scrollToSlide(index, behavior) {
            this.viewports[index]?.scrollIntoView({ behavior, block: 'start' });
        }

        _slideIndexFromHash(hash) {
            if (!hash) return -1;
            return this.slides.findIndex((s) => '#' + s.id === hash);
        }

        _syncHash() {
            const slide = this.slides[this.currentSlide];
            if (!slide || !slide.id) return;
            const newHash = '#' + slide.id;
            if (location.hash !== newHash) {
                // replaceState — keeps the URL in sync without polluting history,
                // so the browser back button exits the deck instead of stepping through slides.
                history.replaceState(null, '', newHash);
            }
        }

        _setupHashNav() {
            // React to external hash changes (anchor link clicks, back/forward if user uses pushState manually)
            window.addEventListener('hashchange', () => {
                const idx = this._slideIndexFromHash(location.hash);
                if (idx >= 0 && idx !== this.currentSlide) this.goTo(idx);
            });
        }

        /* ---------- Custom cursor ----------
           Accent disc that follows the pointer, hidden after idle. */
        _setupCursor() {
            if (!matchMedia('(hover: hover)').matches) return;

            const cursor = document.createElement('div');
            cursor.className = 'chassis-cursor';
            cursor.setAttribute('aria-hidden', 'true');
            document.body.appendChild(cursor);
            document.body.classList.add('chassis-cursor-active');

            const half = 16;  // matches width/height / 2 in CSS
            const IDLE_MS = 2500;
            let idleTimer = null;

            const show = () => {
                cursor.classList.add('visible');
                clearTimeout(idleTimer);
                idleTimer = setTimeout(() => {
                    cursor.classList.remove('visible');
                }, IDLE_MS);
            };
            const hide = () => {
                clearTimeout(idleTimer);
                cursor.classList.remove('visible');
            };

            document.addEventListener('mousemove', (e) => {
                cursor.style.transform = `translate3d(${e.clientX - half}px, ${e.clientY - half}px, 0)`;
                show();
            });
            document.addEventListener('mouseleave', hide);
            document.addEventListener('mouseenter', show);
        }

        /* ---------- Fullscreen ---------- */
        toggleFullscreen() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen?.().catch(() => {});
            } else {
                document.exitFullscreen?.();
            }
        }

        next() { this.goTo(this.currentSlide + 1); }
        prev() { this.goTo(this.currentSlide - 1); }
        first() { this.goTo(0); }
        last() { this.goTo(this.slides.length - 1); }

        /* ---------- Step-aware advance / retreat ----------
           advance() reveals the next .step on the current slide (if any),
           otherwise advances to the next slide. retreat() hides the last
           revealed step, otherwise goes back to the previous slide. */
        advance() {
            const current = this.slides[this.currentSlide];
            const nextStep = current?.querySelector('.step:not(.step-shown)');
            if (nextStep) {
                nextStep.classList.add('step-shown');
                // No stagger on click-reveal — the user's gesture is the trigger.
                this._playReveal(nextStep, 0);
                return;
            }
            this.next();
        }
        retreat() {
            const current = this.slides[this.currentSlide];
            const shown = current?.querySelectorAll('.step.step-shown');
            if (shown && shown.length > 0) {
                const last = shown[shown.length - 1];
                last.classList.remove('step-shown');
                this._cancelReveal(last);
                this._applyHiddenStyle(last);
                return;
            }
            this.prev();
        }

        /* ---------- Intersection observer ----------
           Fire late (>= 80% in view) so reveals play on a settled slide.
           This is the single source of truth for active-slide state.

           Forward:  add .visible, play reveals. (goTo() has already reset
                     the target to pre-reveal state if this is a re-visit,
                     so the animation is fresh either way.)
           Backward: add .visible, rewind to the start of the stepped
                     content — reveals are shown instantly (no replay) and
                     every step is hidden again so the viewer can step
                     through it fresh. */
        _setupIntersectionObserver() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (!entry.isIntersecting) return;
                    const idx = this.viewports.indexOf(entry.target);
                    if (idx < 0) return;
                    const slide = this.slides[idx];

                    if (idx === this.currentSlide) {
                        // Same-slide re-fire (initial load, resize, fullscreen).
                        if (!slide.classList.contains('visible')) {
                            slide.classList.add('visible');
                        }
                        // Idempotent: only plays if not already marked played.
                        this._playSlideReveals(slide);
                        return;
                    }

                    const goingForward = idx > this.currentSlide;
                    this.currentSlide = idx;
                    this._updateNavDots();
                    this._syncHash();

                    slide.classList.add('visible');
                    if (goingForward) {
                        this._playSlideReveals(slide);
                    } else {
                        this._rewindSlide(slide);
                    }
                });
            }, { threshold: 0.8 });

            this.viewports.forEach((viewport) => observer.observe(viewport));
        }

        /* ---------- Keyboard ---------- */
        _setupKeyboardNav() {
            document.addEventListener('keydown', (e) => {
                // Skip when user is editing text
                if (e.target.isContentEditable || /^(INPUT|TEXTAREA|SELECT)$/.test(e.target.tagName)) return;

                switch (e.key) {
                    // Step-aware: consume steps first, then advance slides
                    case 'ArrowDown':
                    case 'ArrowRight':
                    case ' ':
                        e.preventDefault(); this.advance(); break;
                    case 'ArrowUp':
                    case 'ArrowLeft':
                        e.preventDefault(); this.retreat(); break;
                    // Slide-level: always skip past steps
                    case 'PageDown':
                        e.preventDefault(); this.next(); break;
                    case 'PageUp':
                        e.preventDefault(); this.prev(); break;
                    case 'Home':
                        e.preventDefault(); this.first(); break;
                    case 'End':
                        e.preventDefault(); this.last(); break;
                    case 'f':
                    case 'F':
                        e.preventDefault(); this.toggleFullscreen(); break;
                    case 'r':
                    case 'R':
                        e.preventDefault(); this.first(); break;
                }
            });
        }

        /* ---------- Wheel / trackpad ----------
           ALWAYS preventDefault — letting any native wheel scroll through
           races against scrollIntoView + mandatory snap, and blocks macOS
           two-finger horizontal swipes from triggering browser back/forward.
           Whichever axis has the larger magnitude wins, so vertical scroll
           and horizontal trackpad swipes both drive advance/retreat. Lock
           briefly after a gesture so trackpad inertia (continuous small
           deltas) can't spam next(). */
        _setupWheelNav() {
            let locked = false;
            window.addEventListener('wheel', (e) => {
                if (e.ctrlKey) return;                // preserve browser pinch-zoom (ctrl+wheel)
                e.preventDefault();                   // block native scroll + horizontal back-swipe
                if (locked) return;
                const delta = Math.abs(e.deltaX) > Math.abs(e.deltaY) ? e.deltaX : e.deltaY;
                if (Math.abs(delta) < 20) return;     // ignore tiny flicks
                locked = true;
                if (delta > 0) this.advance(); else this.retreat();
                setTimeout(() => { locked = false; }, 500);
            }, { passive: false });
        }

        /* ---------- Touch / swipe ----------
           Horizontal swipes advance / retreat slides; left = next, right =
           prev (matches stories / carousel conventions). Dominantly
           vertical swipes fall through to native scroll-snap so the
           existing top/bottom behavior keeps working. A time budget
           rejects slow pans that were really aborted scrolls. */
        _setupTouchNav() {
            const MIN_DISTANCE = 50;     // px — below this is a tap or jitter
            const MAX_TIME = 600;        // ms — slower than this is a pan, not a swipe
            const DOMINANCE = 1.2;       // horizontal must beat vertical by this factor

            let startX = 0, startY = 0, startTime = 0;
            let tracking = false;

            window.addEventListener('touchstart', (e) => {
                if (document.body.classList.contains('artifact-editor-editing')) { tracking = false; return; }
                if (e.touches.length !== 1) { tracking = false; return; }
                const t = e.touches[0];
                startX = t.clientX;
                startY = t.clientY;
                startTime = performance.now();
                tracking = true;
            }, { passive: true });

            window.addEventListener('touchend', (e) => {
                if (!tracking) return;
                tracking = false;
                const t = e.changedTouches[0];
                const dx = t.clientX - startX;
                const dy = t.clientY - startY;
                const ax = Math.abs(dx), ay = Math.abs(dy);
                if (ax < MIN_DISTANCE) return;
                if (ax < ay * DOMINANCE) return;
                if (performance.now() - startTime > MAX_TIME) return;
                if (dx < 0) this.advance(); else this.retreat();
            }, { passive: true });

            window.addEventListener('touchcancel', () => { tracking = false; }, { passive: true });
        }

        /* ---------- Canvas scaling ----------
           Each scaler holds a fixed 1920×1080 slide. Compute the
           scale factor that fits it inside the viewport and apply via
           CSS custom property. Runs on init, resize, and fullscreen. */
        _setupCanvasScale() {
            const CANVAS_W = 1920;
            const CANVAS_H = 1080;
            const scales = this.scales;

            const update = () => {
                const scale = Math.min(
                    window.innerWidth / CANVAS_W,
                    window.innerHeight / CANVAS_H
                );
                scales.forEach((el) => {
                    el?.style.setProperty('--slide-scale', scale);
                });
            };

            update();
            window.addEventListener('resize', update);
            document.addEventListener('fullscreenchange', () => {
                requestAnimationFrame(update);
            });
        }

        /* ---------- Viewport sync ----------
           Resize / fullscreenchange → realign current slide. Each slide is
           100vh, so a viewport height change leaves the existing scroll
           position out of alignment with the slide top; scroll-snap doesn't
           re-snap on its own. */
        _setupViewportSync() {
            const realign = () => {
                requestAnimationFrame(() => {
                    this._scrollToSlide(this.currentSlide, 'auto');
                });
            };
            window.addEventListener('resize', realign);
            document.addEventListener('fullscreenchange', realign);
        }

        /* ---------- Nav dots ---------- */
        _buildNavDots() {
            // Clear first — prevents duplicates when DOM is re-serialized/re-opened
            this.navDotsContainer.innerHTML = '';
            this.slides.forEach((slide, idx) => {
                const dot = document.createElement('button');
                dot.setAttribute('aria-label', `Go to slide ${idx + 1}`);
                if (idx === 0) dot.classList.add('active');
                dot.addEventListener('click', () => this.goTo(idx));
                this.navDotsContainer.appendChild(dot);
            });
        }

        _updateNavDots() {
            const dots = this.navDotsContainer.querySelectorAll('button');
            dots.forEach((dot, idx) => {
                dot.classList.toggle('active', idx === this.currentSlide);
            });
        }
    }

    /* ---------- Auto-init ---------- */
    function init() {
        // Each slide canvas is its own editable host for the inline editor.
        document.querySelectorAll('.slide').forEach(function (el) {
            el.classList.add('artifact-editable');
        });
        window.slides = new SlidePresentation();
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();

</script>
